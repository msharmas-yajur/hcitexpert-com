[
{% for post in site.posts %}{% assign words = post.content | strip_html | number_of_words %}{% assign rt = words | divided_by: 200 | plus: 1 %}{"t":{{ post.title | jsonify }},"u":{{ post.url | relative_url | jsonify }},"d":"{{ post.date | date: '%Y-%m-%d' }}","y":{{ post.date | date: '%Y' | plus: 0 }},"c":{{ post.categories.first | default: 'Healthcare IT' | jsonify }},"r":{{ rt }}}{% unless forloop.last %},
{% endunless %}{% endfor %}
]
